generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?            // e.g. { orderId, paymentId, trackingNumber }
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

enum NotificationType {
  ORDER_PLACED
  ORDER_CONFIRMED
  ORDER_CANCELLED
  ORDER_SHIPPED
  ORDER_DELIVERED
  PAYMENT_COMPLETED
  PAYMENT_FAILED
  PAYMENT_REFUNDED
}
